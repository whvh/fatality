local function createFoodESP()
    local ws = game:GetService("Workspace")
    local foodMarkers = {}
    
    local function setupFoodMarker(obj, foodType)
        if State.Unloaded then return end
        
        local primaryPart = obj:FindFirstChild("MainMeat") or obj:FindFirstChildWhichIsA("BasePart")
        if not primaryPart then return end
        
        local b = Instance.new("BillboardGui", primaryPart)
        b.Name = "FoodESP"
        b.Adornee = primaryPart
        b.Size = UDim2.new(0, 200, 0, 100)
        b.StudsOffset = Vector3.new(0, 3, 0)
        b.AlwaysOnTop = true
        b.Enabled = false
        
        local l = Instance.new("TextLabel", b)
        l.BackgroundTransparency = 1
        l.Size = UDim2.new(1, 0, 1, 0)
        l.TextColor3 = Color3.new(1, 1, 0)
        l.TextSize = 12
        l.Font = Enum.Font.Code
        l.TextYAlignment = Enum.TextYAlignment.Top
        l.TextXAlignment = Enum.TextXAlignment.Left
        
        foodMarkers[obj] = {billboard = b, label = l, foodType = foodType, part = primaryPart}
    end
    
    local function scanFood()
        if ws:FindFirstChild("Fish") then
            for _, fish in pairs(ws.Fish:GetChildren()) do
                if not fish:FindFirstChild("FoodESP") and not foodMarkers[fish] then
                    setupFoodMarker(fish, "fish")
                end
            end
        end
        
        if ws:FindFirstChild("Food") then
            for _, food in pairs(ws.Food:GetChildren()) do
                if not food:FindFirstChild("FoodESP") and not foodMarkers[food] then
                    local hasCreatureName = food:FindFirstChild("CreatureName")
                    if hasCreatureName then
                        setupFoodMarker(food, "dino")
                    else
                        setupFoodMarker(food, "meat")
                    end
                end
            end
        end
    end
    
    scanFood()
    
    task.spawn(function()
        while not State.Unloaded do
            task.wait(10)
            scanFood()
        end
    end)
    
    if ws:FindFirstChild("Fish") then
        ws.Fish.ChildAdded:Connect(function(child)
            task.wait(0.1)
            setupFoodMarker(child, "fish")
        end)
    end
    
    if ws:FindFirstChild("Food") then
        ws.Food.ChildAdded:Connect(function(child)
            task.wait(0.1)
            local hasCreatureName = child:FindFirstChild("CreatureName")
            if hasCreatureName then
                setupFoodMarker(child, "dino")
            else
                setupFoodMarker(child, "meat")
            end
        end)
    end
    
    local lastUpdate = 0
    local updateInterval = 0.5
    local c = RunService.RenderStepped:Connect(function()
        if State.Unloaded then 
            c:Disconnect()
            return 
        end
        
        local now = tick()
        if now - lastUpdate < updateInterval then return end
        lastUpdate = now
        
        if not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return end
        local playerPos = lp.Character.HumanoidRootPart.Position
        
        for obj, data in pairs(foodMarkers) do
            if not obj.Parent or not data.billboard.Parent then
                if data.billboard.Parent then data.billboard:Destroy() end
                foodMarkers[obj] = nil
            else
                local dist = (playerPos - data.part.Position).Magnitude
                local shouldShow = false
                local lines = {}
                local foodType = data.foodType
                
                if foodType == "fish" and State.FoodESP.Fish.Enabled then
                    if dist <= State.FoodESP.Fish.MaxDistance then
                        shouldShow = true
                        if State.FoodESP.Fish.ShowDistance then
                            table.insert(lines, string.format("%.1fm", dist / 4))
                        end
                        if State.FoodESP.Fish.ShowName and obj:FindFirstChild("CreatureName") then
                            table.insert(lines, obj.CreatureName.Value)
                        end
                        if State.FoodESP.Fish.ShowMeat then
                            local meat = obj:FindFirstChild("Meat")
                            local maxMeat = obj:FindFirstChild("MaxMeat")
                            if meat and maxMeat then
                                table.insert(lines, string.format("%d/%d", math.floor(meat.Value), math.floor(maxMeat.Value)))
                            end
                        end
                        if State.FoodESP.Fish.ShowSize and obj:FindFirstChild("CorpseSize") then
                            table.insert(lines, string.format("Size: %.1f", obj.CorpseSize.Value))
                        end
                    end
                elseif foodType == "meat" and State.FoodESP.Meat.Enabled then
                    if dist <= State.FoodESP.Meat.MaxDistance then
                        shouldShow = true
                        if State.FoodESP.Meat.ShowDistance then
                            table.insert(lines, string.format("%.1fm", dist / 4))
                        end
                        if State.FoodESP.Meat.ShowMeat and obj:FindFirstChild("Meat") then
                            table.insert(lines, string.format("%d/10", math.floor(obj.Meat.Value)))
                        end
                    end
                elseif foodType == "dino" and State.FoodESP.Dinos.Enabled then
                    if dist <= State.FoodESP.Dinos.MaxDistance then
                        local creatureName = obj:FindFirstChild("CreatureName")
                        if creatureName then
                            local fullName = creatureName.Value
                            local baseName = nil
                            
                            for filterName, enabled in pairs(State.FoodESP.Dinos.Filters) do
                                if enabled and fullName:find(filterName) then
                                    baseName = filterName
                                    break
                                end
                            end
                            
                            if baseName then
                                shouldShow = true
                                if State.FoodESP.Dinos.ShowDistance then
                                    table.insert(lines, string.format("%.1fm", dist / 4))
                                end
                                if State.FoodESP.Dinos.ShowName then
                                    table.insert(lines, baseName)
                                end
                                if State.FoodESP.Dinos.ShowMeat then
                                    local meat = obj:FindFirstChild("Meat")
                                    local maxMeat = obj:FindFirstChild("MaxMeat")
                                    if meat and maxMeat then
                                        table.insert(lines, string.format("%d/%d", math.floor(meat.Value), math.floor(maxMeat.Value)))
                                    end
                                end
                                if State.FoodESP.Dinos.ShowSize and obj:FindFirstChild("CorpseSize") then
                                    table.insert(lines, string.format("Size: %.1f", obj.CorpseSize.Value))
                                end
                            end
                        end
                    end
                end
                
                data.billboard.Enabled = shouldShow
                if shouldShow then
                    data.label.Text = table.concat(lines, "\n")
                end
            end
        end
    end)
    table.insert(Connections, c)
end

