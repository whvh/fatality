local heartbeatConn = RunService.Heartbeat:Connect(function()
    if State.Unloaded then return end
    
    if lp.Character then
        if State.Hitbox.Enabled and lp.Character:FindFirstChild("AttackPart") then
            local p = lp.Character.AttackPart
            p.Size = Vector3.new(State.Hitbox.X, State.Hitbox.Y, State.Hitbox.Z)
            p.Transparency = State.Hitbox.Transparency
            p.CanCollide = false
        end
    end
    
    if State.World.Enabled then
        local Lighting = game:GetService("Lighting")
        
        if State.World.Atmosphere.Enabled then
            local atm = Lighting:FindFirstChildOfClass("Atmosphere")
            if not atm then
                atm = Instance.new("Atmosphere", Lighting)
            end
            atm.Density = State.World.Atmosphere.Density
            atm.Offset = State.World.Atmosphere.Offset
            atm.Haze = State.World.Atmosphere.Haze
        end
        
        local cc = Lighting:FindFirstChildOfClass("ColorCorrectionEffect")
        if not cc then
            cc = Instance.new("ColorCorrectionEffect", Lighting)
        end
        cc.Enabled = State.World.ColorCorrection.Enabled
        if State.World.ColorCorrection.Enabled then
            cc.Brightness = State.World.ColorCorrection.Brightness
            cc.Contrast = State.World.ColorCorrection.Contrast
            cc.Saturation = State.World.ColorCorrection.Saturation
        end
        
        local blur = Lighting:FindFirstChildOfClass("BlurEffect")
        if not blur then
            blur = Instance.new("BlurEffect", Lighting)
        end
        blur.Enabled = State.World.Blur.Enabled
        if State.World.Blur.Enabled then
            blur.Size = State.World.Blur.Size
        end
        
        local bloom = Lighting:FindFirstChildOfClass("BloomEffect")
        if not bloom then
            bloom = Instance.new("BloomEffect", Lighting)
        end
        bloom.Enabled = State.World.Bloom.Enabled
        if State.World.Bloom.Enabled then
            bloom.Intensity = State.World.Bloom.Intensity
            bloom.Size = State.World.Bloom.Size
            bloom.Threshold = State.World.Bloom.Threshold
        end
        
        if State.World.TimeOfDay.Enabled then
            Lighting.ClockTime = State.World.TimeOfDay.Hour
        end
    end
end)
