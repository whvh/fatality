local function CreatePage(name)
    local Page = Instance.new("ScrollingFrame", PageContainer)
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.Visible = (name == State.CurrentTab)
    Page.ScrollBarThickness = 0
    Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Instance.new("UIListLayout", Page).Padding = UDim.new(0, 5)
    
    Pages[name] = Page
    
    local TabBtn = Instance.new("TextButton", TabFrame)
    TabBtn.Size = UDim2.new(1, 0, 0, 40)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text = name:upper()
    TabBtn.Font = Enum.Font.Code
    TabBtn.TextColor3 = (name == State.CurrentTab) and Color3.new(1,1,1) or Color3.fromRGB(100,100,100)
    TabBtn.TextSize = 13
    
    TabBtn.MouseButton1Click:Connect(function()
        for n, p in pairs(Pages) do p.Visible = (n == name) end
        for n, b in pairs(TabButtons) do b.TextColor3 = (n == name) and Color3.new(1,1,1) or Color3.fromRGB(100,100,100) end
        State.CurrentTab = name
    end)
    
    TabButtons[name] = TabBtn
    return Page
end

local function CreateExpandable(parent, text, state_obj, state_key, height)
    local Container = Instance.new("Frame", parent)
    Container.Size = UDim2.new(1, 0, 0, 32)
    Container.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
    Container.BorderSizePixel = 0
    Container.ClipsDescendants = true
    
    local Btn = Instance.new("TextButton", Container)
    Btn.Size = UDim2.new(1, 0, 0, 32)
    Btn.BackgroundTransparency = 1
    Btn.Text = "  [+] " .. text:lower()
    Btn.Font = Enum.Font.Code
    Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    Btn.TextSize = 13
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    
    local Inner = Instance.new("ScrollingFrame", Container)
    Inner.Position = UDim2.new(0, 10, 0, 35)
    Inner.Size = UDim2.new(1, -15, 0, height)
    Inner.BackgroundTransparency = 1
    Inner.ScrollBarThickness = 4
    Inner.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Inner.CanvasSize = UDim2.new(0, 0, 0, 0)
    local layout = Instance.new("UIListLayout", Inner)
    layout.Padding = UDim.new(0, 5)
    
    Btn.MouseButton1Click:Connect(function()
        state_obj[state_key] = not state_obj[state_key]
        local targetSize = state_obj[state_key] and UDim2.new(1, 0, 0, height + 40) or UDim2.new(1, 0, 0, 32)
        TweenService:Create(Container, TweenInfo.new(0.3), {Size = targetSize}):Play()
        Btn.Text = state_obj[state_key] and "  [-] " .. text:lower() or "  [+] " .. text:lower()
    end)
    return Inner
end

