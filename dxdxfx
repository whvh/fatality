local function saveConfig(name)
    if name == "" or name == "  config name..." then return end
    local data = HttpService:JSONEncode(State)
    writefile(configFolder .. "/" .. name .. ".json", data)
end

local function loadConfig(name)
    if name == "" then return end
    local success, data = pcall(function()
        return readfile(configFolder .. "/" .. name .. ".json")
    end)
    if success then
        local decoded = HttpService:JSONDecode(data)
        for k, v in pairs(decoded) do
            if k ~= "Unloaded" and k ~= "Visible" and k ~= "CurrentTab" and k ~= "Bind" then
                State[k] = v
            end
        end
    end
end

local function deleteConfig(name)
    if name == "" then return end
    pcall(function()
        delfile(configFolder .. "/" .. name .. ".json")
    end)
end

local function refreshConfigs()
    for _, child in pairs(configListFrame:GetChildren()) do
