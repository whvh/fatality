local function createESP(player)
    if player == lp then return end
    local function setupGui(character)
        if State.Unloaded then return end
        local head = character:WaitForChild("Head", 10)
        if not head then return end
        local b = Instance.new("BillboardGui", head)
        b.Name = "DinoESP"
        b.Adornee = head
        b.Size = UDim2.new(0, 300, 0, 250)
        b.StudsOffset = Vector3.new(0, 5, 0)
        b.AlwaysOnTop = true
        
        local l = Instance.new("TextLabel", b)
        l.BackgroundTransparency = 1
        l.Size = UDim2.new(1, 0, 1, 0)
        l.TextColor3 = Color3.new(1, 1, 1)
        l.TextSize = 13
        l.Font = Enum.Font.Code
        l.TextYAlignment = Enum.TextYAlignment.Top
        l.TextXAlignment = Enum.TextXAlignment.Left
        
        local lastUpdate = 0
        local c; c = RunService.RenderStepped:Connect(function()
            if State.Unloaded or not b.Parent then c:Disconnect() return end
            
            local now = tick()
            if now - lastUpdate < 0.1 then return end
            lastUpdate = now
            
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") and head then
                local dist = (lp.Character.HumanoidRootPart.Position - head.Position).Magnitude
                if dist > State.ESP.MaxDistance then
                    b.Enabled = false
                    return
                end
            end
            
            b.Enabled = State.ESP.Enabled
            if not State.ESP.Enabled then return end
            
            local info = character:FindFirstChild("CreatureInfo")
            local surv = info and info:FindFirstChild("Survival")
            local combat = info and info:FindFirstChild("Combat")
            
            if not surv then return end
            
            local lines = {}
            
            if State.ESP.ShowPlayerName then
                local playerObj = game.Players:GetPlayerFromCharacter(character)
                if playerObj then
                    table.insert(lines, "Player: " .. playerObj.Name)
                end
            end
            
            if State.ESP.ShowDinoName and character:FindFirstChild("CreatureName") then
                table.insert(lines, "Dino: " .. character.CreatureName.Value)
            end
            
            if State.ESP.ShowGrowth then
                table.insert(lines, string.format("Growth: %.2f%%", surv.Growth.Value))
            end
            
            if State.ESP.ShowHP and character:FindFirstChild("Humanoid") then
                local hum = character.Humanoid
                local hpPercent = (hum.Health / hum.MaxHealth) * 100
                table.insert(lines, string.format("HP: %.0f%%", hpPercent))
            end
            
            if State.ESP.ShowBlood then
                table.insert(lines, string.format("Blood: %.2f%%", surv.Blood.Value))
            end
            
            if State.ESP.ShowHunger then
                local maxHunger = surv:FindFirstChild("MaxHunger")
                if maxHunger then
                    table.insert(lines, string.format("Hunger: %d/%d", math.floor(surv.Hunger.Value), math.floor(maxHunger.Value)))
                else
                    table.insert(lines, string.format("Hunger: %.2f%%", surv.Hunger.Value))
                end
            end
            
            if State.ESP.ShowThirst then
                local maxThirst = surv:FindFirstChild("MaxThirst")
                if maxThirst then
                    table.insert(lines, string.format("Thirst: %d/%d", math.floor(surv.Thirst.Value), math.floor(maxThirst.Value)))
                else
                    table.insert(lines, string.format("Thirst: %.2f", surv.Thirst.Value))
                end
            end
            
            if State.ESP.ShowEnergy then
                table.insert(lines, string.format("Energy: %d/%d", math.floor(surv.Energy.Value), math.floor(surv.MaxEnergy.Value)))
            end
            
            if State.ESP.ShowOxygen then
                table.insert(lines, string.format("Oxygen: %d/%d", math.floor(surv.Oxygen.Value), math.floor(surv.MaxOxygen.Value)))
            end
            
            if State.ESP.ShowHeadFracture then
                table.insert(lines, string.format("Head Fracture: %.2f%%", surv.HeadFracture.Value))
            end
            
            if State.ESP.ShowLegFracture then
                table.insert(lines, string.format("Leg Fracture: %.2f%%", surv.LegFracture.Value))
            end
            
            if State.ESP.ShowStress then
                table.insert(lines, string.format("Stress: %.2f%%", surv.Stress.Value))
            end
            
            l.Text = table.concat(lines, "\n")
        end)
        table.insert(Connections, c)
    end
    player.CharacterAdded:Connect(setupGui)
    if player.Character then setupGui(player.Character) end
end

